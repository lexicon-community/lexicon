{
  "lexicon": 1,
  "id": "app.skydrops.feed.broadcast",
  "defs": {
    "main": {
      "type": "record",
      "description": "A satellite broadcast post in the Skydrops firmament.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["text", "createdAt"],
        "properties": {
          "text": { "type": "string", "maxLength": 10000 },
          "signalStrength": { "type": "integer", "minimum": 1, "maximum": 100 },
          "transmissionType": { "type": "string", "knownValues": ["public", "private", "encrypted"] },
          "facets": {
            "type": "array",
            "items": { "type": "ref", "ref": "app.bsky.richtext.facet" }
          },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
