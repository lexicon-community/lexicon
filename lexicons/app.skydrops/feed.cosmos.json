{
  "lex": 1,
  "id": "app.skydrops.feed.cosmos",
  "defs": {
    "main": {
      "type": "record",
      "description": "The primary video feed for Skydrops, located in the Firmament.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["video", "createdAt"],
        "properties": {
          "video": { "type": "blob", "accept": ["video/mp4", "video/webm"] },
          "aspectRatio": {
            "type": "object",
            "properties": {
              "width": { "type": "integer" },
              "height": { "type": "integer" }
            }
          },
          "caption": { "type": "string", "maxLength": 500 },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
