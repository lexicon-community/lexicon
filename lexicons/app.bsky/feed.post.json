{
  "lexicon": 1,
  "id": "app.bsky.feed.post",
  "defs": {
    "main": {
      "type": "record",
      "description": "A Bluesky post record.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["text", "createdAt"],
        "properties": {
          "text": { "type": "string", "maxLength": 3000, "maxGraphemes": 300 },
          "facets": { "type": "array", "items": { "type": "ref", "ref": "app.bsky.richtext.facet" } },
          "reply": { "type": "ref", "ref": "#replyRef" },
          "embed": { "type": "union", "refs": ["app.bsky.embed.images", "app.bsky.embed.video", "app.bsky.embed.external", "app.bsky.embed.record"] },
          "langs": { "type": "array", "items": { "type": "string", "format": "language" }, "maxLength": 3 },
          "labels": { "type": "union", "refs": ["com.atproto.label.defs#selfLabels"] },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    },
    "replyRef": {
      "type": "object",
      "required": ["root", "parent"],
      "properties": {
        "root": { "type": "ref", "ref": "com.atproto.repo.strongRef" },
        "parent": { "type": "ref", "ref": "com.atproto.repo.strongRef" }
      }
    }
  }
}
